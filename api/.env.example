########################################
# GENERAL
########################################

DEV=example_value
PORT=8000

########################################
# TRAEFIK / TLS
########################################

LETSENCRYPT_EMAIL=your_email@example.com

########################################
# DATABASE
########################################

DATABASE_URL=postgresql://example_user:example_password@db:5432/example_database
POSTGRES_USER=example_user
POSTGRES_PASSWORD=example_password
POSTGRES_DB=example_database
POSTGRES_PORT=5444

########################################
# AUTH / SECURITY
########################################

AUTH_SYSTEM_URL=https://example.com/api/auth
AUTH_TOKEN=your_auth_token_here
SESSION_SECRET_KEY=example_session_secret
AUTH_TYPE=jwt
RATING_ENCRYPTION_KEY=example_encryption_key

########################################
# APP MODE
########################################

MODE=Web2

########################################
# WEATHER API
########################################

WEATHER_BASE_URL=https://api.openweathermap.org/data/2.5/weather
WEATHER_API_KEY=your_api_key_here
WEATHER_BEARER_TOKEN=your_bearer_token_here
WEATHER_UNITS=metric

########################################
# MLFLOW
########################################

MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_ARTIFACT_ROOT=/mlflow/artifacts

########################################
# EMQX / MQTT
########################################

EMQX_DASHBOARD_USER=admin
EMQX_DASHBOARD_PASS=public

MQTT_HOST=emqx
MQTT_PORT=1883
MQTT_USER=admin
MQTT_PASS=public
MQTT_TOPIC=org/+/building/+/device/+/status/
MQTT_CLIENT_ID=qoe-mqtt-subscriber

EMQX_ACL_SECRET=example_acl_secret

########################################
# AUTHELIA
########################################

AUTHELIA_JWT_SECRET=example_jwt_secret
AUTHELIA_SESSION_SECRET=example_session_secret
AUTHELIA_STORAGE_ENCRYPTION_KEY=example_storage_encryption_key

########################################
# REDIS
########################################

REDIS_HOST=redis
REDIS_PORT=6379

########################################
# CORS
########################################

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:5173,http://127.0.0.1:3001
LOCAL_NETWORK_IP=192.168.1.70
LOCAL_NETWORK_PORTS=3000,3001,5173

emqx_acl_secret=example_acl_secret